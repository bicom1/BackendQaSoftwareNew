EMAIL_PROVIDER=smtp
EMAIL_USER=ibrahim@bicommunications.net
EMAIL_PASSWORD="@bicom3211"
SMTP_HOST=mail.bicommunications.net
SMTP_PORT=465
SMTP_SECURE=true
FRONTEND_URL=http://localhost:5173
# Allow POST /register-user without admin token (Postman bootstrap — set false in production)
ALLOW_PUBLIC_REGISTER=true
# OTP is sent to the user's registered email — not the terminal
EMAIL_DEV_FALLBACK=false
EMAIL_DEV_LOG=false

# --- If OTP email fails, fix EMAIL_PASSWORD (cPanel mailbox password) and run: npm run test:email ---
# Option 2: Gmail App Password (https://myaccount.google.com/apppasswords)
# EMAIL_PROVIDER=gmail
# GMAIL_USER=yourname@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# OTP password reset (Redis)
OTP_SECRET=bicom-otp-secret-change-in-production
OTP_EXPIRY_SECONDS=600
OTP_VERIFIED_TTL_SECONDS=900
OTP_MAX_REQUESTS_PER_HOUR=3
FORGOT_PASSWORD_IP_LIMIT=5
VERIFY_OTP_IP_LIMIT=10
RESET_PASSWORD_IP_LIMIT=5
JWT_SECRET=bicom
JWT_EXPIRES_IN=7d
BITRIX_SECRET=your_shared_secret_here
DEFAULT_OWNER_ID=6870df41da1577fe0e88849d     # fallback ObjectId (must exist in users collection)
DEFAULT_USER_EMAIL=testuser@gmail.com   

# Timezone for cron jobs
TZ=America/New_York

# Optional: Control whether cron jobs run
ENABLE_CRON_JOBS=true




