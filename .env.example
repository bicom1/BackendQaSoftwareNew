PORT=3001
# Local MongoDB
# MONGO_URL=mongodb://127.0.0.1:27017/bicc
# OLD Atlas (bic.vifauen)
# MONGO_URL=mongodb+srv://qcdev:YOUR_PASSWORD@bic.vifauen.mongodb.net/bicc?retryWrites=true&w=majority
# NEW Atlas (cluster0.3f5zxhd) — encode @ in password as %40
MONGO_URL=mongodb+srv://qcdev_db_user:YOUR_PASSWORD@cluster0.3f5zxhd.mongodb.net/bicc?retryWrites=true&w=majority
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=change_me_in_production
FRONTEND_URL=http://localhost:5173

# Email (nodemailer) — pick one provider
EMAIL_PROVIDER=smtp
EMAIL_USER=you@yourdomain.com
EMAIL_PASSWORD="your-email-password"
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=465
SMTP_SECURE=true
EMAIL_DEV_FALLBACK=false
EMAIL_DEV_LOG=false

# Optional display name for outgoing mail
# EMAIL_FROM="BICOMM QA <you@yourdomain.com>"

# Gmail (recommended for dev): create App Password at https://myaccount.google.com/apppasswords
# EMAIL_PROVIDER=gmail
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Brevo free SMTP: https://www.brevo.com
# EMAIL_PROVIDER=brevo
# BREVO_LOGIN=your-login@email.com
# BREVO_SMTP_KEY=your-smtp-key

# OTP password reset
OTP_SECRET=change_me_otp_secret
OTP_EXPIRY_SECONDS=600
OTP_VERIFIED_TTL_SECONDS=900
OTP_MAX_REQUESTS_PER_HOUR=3
FORGOT_PASSWORD_IP_LIMIT=5
VERIFY_OTP_IP_LIMIT=10
RESET_PASSWORD_IP_LIMIT=5
